#!/usr/bin/env bash
# speaker: atomic speaker-routing across MPD outputs + OwnTone speaker
# selection + PipeWire default sink. Reads per-machine config from
# ~/.config/mpd-owntone-bridge/config.env.
#
# Usage:
#   speaker laptop          # laptop speakers via MPD pulse output
#   speaker denon           # AirPlay to Denon only
#   speaker kitchen         # AirPlay to Kitchen only
#   speaker multi           # AirPlay to both Denon and Kitchen (default set)
#   speaker multi <ids...>  # AirPlay to explicit owntone output ids
#   speaker status          # print current routing
#   speaker list            # list discoverable owntone outputs

set -u -o pipefail

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/mpd-owntone-bridge/config.env"
STATE="${XDG_CONFIG_HOME:-$HOME/.config}/mpd-owntone-bridge/state.json"

[[ -f "$CONFIG" ]] || { echo "missing config: $CONFIG" >&2; exit 1; }
# shellcheck source=/dev/null
. "$CONFIG"

CURL=(command curl --silent --max-time 2)
MPC=(mpc -p "$MPD_PORT" -h "$MPD_HOST")

info()   { printf '\033[0;32m[speaker]\033[0m %s\n' "$*"; }
warn()   { printf '\033[1;33m[speaker]\033[0m %s\n' "$*" >&2; }
err()    { printf '\033[0;31m[speaker]\033[0m %s\n' "$*" >&2; exit 1; }

# -------- low-level helpers --------

state_read()  { [[ -f "$STATE" ]] && cat "$STATE" || echo '{}'; }
state_write() { echo "$1" > "$STATE"; }

owntone_outputs_json() { "${CURL[@]}" "${OWNTONE_API}/outputs"; }

owntone_set_selected() {
  # $1 = output id, $2 = true|false
  "${CURL[@]}" -X PUT "${OWNTONE_API}/outputs/$1" \
    -H 'Content-Type: application/json' \
    -d "{\"selected\": $2}" >/dev/null
}

owntone_set_volume() {
  "${CURL[@]}" -X PUT "${OWNTONE_API}/outputs/$1" \
    -H 'Content-Type: application/json' \
    -d "{\"volume\": $2}" >/dev/null
}

owntone_get_volume() {
  "${CURL[@]}" "${OWNTONE_API}/outputs/$1" | jq -r '.volume // empty'
}

owntone_is_selected() {
  "${CURL[@]}" "${OWNTONE_API}/outputs/$1" | jq -r '.selected // false'
}

# Cold receivers (e.g., an AVR waking from standby) often reject the first RTSP
# handshake; owntone then flips `selected` back to false. Poll and re-select
# until every target sticks, or give up after a handful of attempts.
ensure_selected_all() {
  local ids=("$@") attempt id any_missing
  for attempt in 1 2 3 4 5; do
    sleep 1
    any_missing=0
    for id in "${ids[@]}"; do
      if [[ "$(owntone_is_selected "$id")" != "true" ]]; then
        any_missing=1
        warn "speaker $id not ready (attempt $attempt/5), re-selecting"
        owntone_set_selected "$id" true
      fi
    done
    (( any_missing == 0 )) && return 0
  done
  local failed=0
  for id in "${ids[@]}"; do
    if [[ "$(owntone_is_selected "$id")" != "true" ]]; then
      warn "speaker $id failed to activate (receiver off or unreachable?)"
      failed=1
    fi
  done
  return $failed
}

owntone_deselect_all_airplay() {
  local ids
  ids=$(owntone_outputs_json | jq -r '.outputs[] | select(.type | startswith("AirPlay")) | .id')
  while read -r id; do
    [[ -z "$id" ]] && continue
    owntone_set_selected "$id" false
  done <<< "$ids"
}

mpd_enable()  { "${MPC[@]}" enable  "$1" >/dev/null; }
mpd_disable() { "${MPC[@]}" disable "$1" >/dev/null; }

owntone_player_play() { "${CURL[@]}" -X PUT "${OWNTONE_API}/player/play" >/dev/null; }
owntone_player_stop() { "${CURL[@]}" -X PUT "${OWNTONE_API}/player/stop" >/dev/null; }

name_to_id() {
  # map friendly name to owntone output id via config env vars; fall through
  # to passing the arg as-is (assumed numeric id).
  case "$1" in
    denon)   echo "$SPEAKER_DENON" ;;
    kitchen) echo "$SPEAKER_KITCHEN" ;;
    *)       echo "$1" ;;
  esac
}

# Resolve each arg to (id, human_name) pairs. Echoes tab-separated lines.
resolve_speakers() {
  local arg id human
  for arg in "$@"; do
    id="$(name_to_id "$arg")"
    if [[ -z "$id" ]]; then
      warn "no known id for '$arg' (check $CONFIG)"; continue
    fi
    human=$(owntone_outputs_json | jq -r --arg id "$id" '.outputs[] | select(.id==$id) | .name' 2>/dev/null)
    [[ -z "$human" ]] && human="$arg"
    printf '%s\t%s\n' "$id" "$human"
  done
}

# -------- actions --------

nudge_bridge_reemit() {
  # Tell the metadata bridge to re-issue the current track's metadata into
  # the new RTSP session owntone just opened for the selected speaker(s).
  systemctl --user kill -s USR1 mpd-owntone-metadata.service 2>/dev/null || true
}

go_laptop() {
  info "routing: laptop speakers"
  owntone_deselect_all_airplay
  owntone_player_stop
  mpd_enable  "$MPD_OUT_LOCAL"
  mpd_disable "$MPD_OUT_AIRPLAY"
  if [[ -n "${PIPEWIRE_LAPTOP_SINK:-}" ]]; then
    pactl set-default-sink "$PIPEWIRE_LAPTOP_SINK" >/dev/null 2>&1 || true
  fi
}

go_airplay() {
  # $@: owntone output ids
  local ids=("$@")
  info "routing: airplay -> ${#ids[@]} speaker(s)"
  mpd_disable "$MPD_OUT_LOCAL"
  mpd_enable  "$MPD_OUT_AIRPLAY"
  owntone_deselect_all_airplay
  local id
  for id in "${ids[@]}"; do
    owntone_set_selected "$id" true
  done
  ensure_selected_all "${ids[@]}" || true
  # If MPD is playing, kick owntone to start so the pipe is consumed.
  if "${MPC[@]}" status 2>/dev/null | grep -q '^\[playing\]'; then
    owntone_player_play
  fi
  # Capture baseline for multi-room ratio scaling.
  if (( ${#ids[@]} > 1 )); then
    capture_multi_baseline "${ids[@]}"
  else
    clear_multi_baseline
  fi
  # Nudge the bridge so the metadata lands in the fresh RTSP session
  # (otherwise the receiver shows the pipe's default "mpd.pcm / Unknown
  # artist" until MPD changes tracks).
  nudge_bridge_reemit
}

capture_multi_baseline() {
  local obj='{}' id vol
  for id in "$@"; do
    vol=$(owntone_get_volume "$id")
    [[ -z "$vol" ]] && vol=40
    obj=$(jq --arg id "$id" --argjson vol "$vol" '.[$id]=$vol' <<< "$obj")
  done
  local merged
  merged=$(state_read | jq --argjson b "$obj" '.multi_baseline=$b')
  state_write "$merged"
  info "multi-room baseline captured: $(jq -c .multi_baseline <<< "$merged")"
}

clear_multi_baseline() {
  local merged
  merged=$(state_read | jq 'del(.multi_baseline)')
  state_write "$merged"
}

# -------- commands --------

cmd_status() {
  echo "--- MPD outputs ---"
  "${MPC[@]}" outputs
  echo
  echo "--- OwnTone selected outputs ---"
  owntone_outputs_json | jq -r '.outputs[] | select(.selected==true) | "  \(.name) [\(.type)] vol=\(.volume)"'
  echo
  echo "--- PipeWire default sink ---"
  pactl info 2>/dev/null | grep "Default Sink" || true
  echo
  echo "--- Multi-room baseline ---"
  state_read | jq '.multi_baseline // "none"'
}

cmd_list() {
  owntone_outputs_json | jq -r '.outputs[] | "\(.id)\t\(.type)\t\(.selected)\t\(.volume)\t\(.name)"' \
    | column -t -s $'\t' -N ID,TYPE,SEL,VOL,NAME
}

main() {
  local cmd="${1:-status}"; shift || true
  case "$cmd" in
    laptop)  go_laptop ;;
    denon)   go_airplay "$SPEAKER_DENON" ;;
    kitchen) go_airplay "$SPEAKER_KITCHEN" ;;
    multi)
      if (( $# == 0 )); then
        set -- denon kitchen
      fi
      local ids=()
      while read -r id _; do ids+=("$id"); done < <(resolve_speakers "$@")
      (( ${#ids[@]} >= 1 )) || err "no valid speakers after resolution"
      go_airplay "${ids[@]}"
      ;;
    status) cmd_status ;;
    list)   cmd_list ;;
    *)
      cat >&2 <<'EOF'
usage: speaker {laptop|denon|kitchen|multi [ids...]|status|list}
EOF
      exit 2 ;;
  esac
}

main "$@"
